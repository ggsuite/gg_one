# https://dart.dev/guides/libraries/private-files
# Created by `dart pub`
.dart_tool/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock

node_modules
coverage
build
*.vm.json
.DS_Store
.aicode
# Ignore .gg contents, but keep the check-state and ticket files trackable.
# ».gg« (the bare directory pattern) must not be used here: git never
# descends into an excluded directory, so the »!«-negations below would
# have no effect and .gg/.gg.json would never reach CI.
.gg/*
!.gg/.gg.json

# Local cross-repo dev override (not for commit)
pubspec_overrides.yaml
!.gg/.ticket.json
.gg/.gg-publish.json
